# Токен Telegram-бота от BotFather
BOT_TOKEN=

# Ключ для OpenAI или совместимого провайдера (OpenRouter, DeepSeek, ...).
# Прямой OpenAI:  sk-proj-... (https://platform.openai.com/api-keys)
# OpenRouter:     sk-or-v1-... (https://openrouter.ai/keys)
OPENAI_API_KEY=

# Базовый URL API. Оставь пустым для прямого OpenAI.
# Для OpenRouter: https://openrouter.ai/api/v1
# Для DeepSeek:   https://api.deepseek.com
OPENAI_BASE_URL=

# Модель для текста и анализа.
# Для OpenAI:     gpt-4o-mini
# Для OpenRouter: openai/gpt-4o-mini, deepseek/deepseek-chat-v3, и т.д.
OPENAI_MODEL=gpt-4o-mini

# Модель для разбора фото (Vision). По умолчанию = OPENAI_MODEL.
OPENAI_VISION_MODEL=gpt-4o-mini

# Модель транскрипции голосовых сообщений (только прямой OpenAI поддерживает).
OPENAI_WHISPER_MODEL=whisper-1

# Максимум выходных токенов
OPENAI_MAX_TOKENS=3000

# Строка подключения к PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Рабочие часы для напоминаний (формат: целое число от 0 до 23)
REMINDER_HOUR_START=8
REMINDER_HOUR_END=18

# Час, когда бот рассылает вечернюю сводку (по умолчанию 19)
EVENING_SUMMARY_HOUR=19

# Telegram-id девушек из отдела КРОСС через запятую.
# Они смогут создавать заявки и назначать их монтёрам.
# Узнать id можно через бота @userinfobot или @getmyid_bot.
DISPATCHER_IDS=

# Часовой пояс (опционально, по умолчанию Asia/Almaty)
TZ=Asia/Almaty
